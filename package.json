{
  "name": "vodie-studio",
  "version": "0.1.1",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "dist:win": "npm run build && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "typescript": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.vodie.studio",
    "productName": "Vodie Studio",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/ffmpeg-static/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Vodie-Studio-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vodie Studio"
    }
  }
}
